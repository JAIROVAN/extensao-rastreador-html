{
  "manifest_version": 3,
  "name": "Rastreador HTML",
  "version": "1.0.3",
  "minimum_chrome_version": "114",
  "description": "Inspeciona elementos HTML e gera seletores e sugestoes de automacao com Puppeteer.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Rastreador HTML",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "resultado.html"
  }
}
